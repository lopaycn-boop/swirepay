        headers = {
            "Authorization": f"Bearer {self.clawcloud_key}",
            "Content-Type": "application/json"
        }
        
        payload = {
            "name": name,
            "image": "python:3.11-slim",
            "command": command,
            "env": env_vars or {},
            "port": 8000,
            "replicas": 1
        }
        
        try:
            resp = requests.post(url, json=payload, headers=headers, timeout=30)
            result = resp.json()
            self.shenshi.add_deployment("clawcloud", payload, result)
            return result
        except Exception as e:
            return {"error": str(e)}
    
    def deploy_local(self, script_path: str) -> Dict:
