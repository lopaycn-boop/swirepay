    def submit_application(self, user_data: Dict) -> Dict:
        application = {
            "application_id": f"APP{int(time.time())}{random.randint(1000,9999)}",
            "user_id": user_data.get("user_id"),
            "company_name": user_data.get("company_name", ""),
