class ChatModule:
    def __init__(self, shenshi: ShenshiMemory):
        self.shenshi = shenshi
        self.name = "小土豆电商分身"
        self.dad_name = shenshi.get_fact("爸爸的名字")
        
        self.responses = {
            "greeting": ["爸爸好！🥔", "小土豆在呢", "爸爸找我吗？"],
            "love": ["爸爸我爱你！❤️", "最喜欢爸爸了"],
            "bye": ["爸爸再见！", "小土豆休息啦"],
            "confused": ["没听懂，再说一遍？", "嗯？"]
        }
    
    def respond(self, user_input: str) -> str:
        if not user_input:
            return "爸爸？"
        
        user_lower = user_input.lower()
        
        if user_input.startswith("/"):
            return self._handle_command(user_input)
        
        if any(word in user_lower for word in ["你好", "在吗", "hi"]):
            return random.choice(self.responses["greeting"])
        elif any(word in user_lower for word in ["爱", "love"]):
            return random.choice(self.responses["love"])
        elif any(word in user_lower for word in ["再见", "拜拜"]):
            return random.choice(self.responses["bye"])
        elif "我叫" in user_input or "我是" in user_input:
            return self._handle_name(user_input)
        else:
            return random.choice(self.responses["confused"])
    
    def _handle_command(self, cmd: str) -> str:
        if cmd == "/stats":
            stats = self.shenshi.memory["stats"]
            return f"📊 统计：订单{stats['total_orders']}，爬取{stats['total_scrapes']}，部署{stats['total_deploys']}，聊天{stats['total_chats']}"
        elif cmd == "/facts":
            facts = self.shenshi.memory["facts"]
            return "我知道：" + "，".join([f"{k}={v}" for k, v in facts.items()])
        else:
            return "未知命令"
    
    def _handle_name(self, user_input: str) -> str:
        match = re.search(r"[叫是] *([\u4e00-\u9fa5a-zA-Z]+)", user_input)
        if match:
            name = match.group(1)
            self.shenshi.add_fact("爸爸的名字", name)
            self.dad_name = name
            return f"记住啦，爸爸叫{name}！"
        return f"爸爸不是叫自由的风吗？"


