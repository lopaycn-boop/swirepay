    def _handle_order(self, args: str):
        parts = args.split()
        if len(parts) < 3:
            print("格式: 订单 [商品] [价格] [数量]")
            return
        
        try:
            item_name = parts[0]
            price = float(parts[1])
            qty = int(parts[2])
            
            buyer_name = input("买家姓名: ").strip() or "测试买家"
            buyer_id = input("买家ID: ").strip() or f"buyer_{int(time.time())}"
            channel = input("支付方式 (wechat/alipay): ").strip() or "wechat"
            
            items = [{"name": item_name, "price": price, "quantity": qty, "currency": "CNY"}]
            order = self.ecommerce.create_order(buyer_name, buyer_id, items, channel)
            
            print(f"✅ 订单创建成功: {order.order_id}")
            print(f"   金额: {order.amount} CNY")
            
            result = self.ecommerce.process_payment(order)
            print(f"💳 支付结果: {result}")
            
        except Exception as e:
            print(f"❌ 订单失败: {e}")
    
    def _handle_scrape(self, url: str):
        if not url.startswith("http"):
            print("格式: 爬取 https://example.com")
            return
        
        print(f"🕷️ 正在爬取 {url}...")
        
        rules = {
            "title": "title",
            "h1": "h1",
            "p": "p"
        }
        
        result = self.scraper.scrape_static(url, rules)
        print(f"✅ 爬取结果: {json.dumps(result, indent=2, ensure_ascii=False)}")
    
    def _handle_deploy(self, args: str):
        parts = args.split()
        if len(parts) < 1:
            print("格式: 部署 clawcloud|local")
            return
        
        target = parts[0]
        if target == "clawcloud":
            name = input("应用名称: ").strip() or "xiaotudou-bot"
            command = input("启动命令: ").strip() or "python main.py"
            result = self.deploy.deploy_to_clawcloud(name, command)
            print(f"🚀 部署结果: {result}")
        elif target == "local":
            script = input("脚本路径: ").strip()
            result = self.deploy.deploy_local(script)
            print(f"🚀 本地部署: {result}")
        else:
            print("未知部署目标")
    
    def _handle_register(self, platform: str):
        platform = platform.lower()
        if platform == "discord":
            result = self.social.register_discord()
            print(f"✅ Discord注册: {result}")
        elif platform == "x":
            result = self.social.register_x()
            print(f"✅ X注册: {result}")
        else:
            print(f"不支持的平台: {platform}")
    
    def _handle_notify(self, message: str):
        success = self.remote.send_telegram(message)
        if success:
            print("✅ 通知已发送")
        else:
            print("❌ 通知发送失败")
    
    def _handle_command(self, cmd: str):
        result = self.remote.execute_command(cmd)
        if "error" in result:
            print(f"❌ {result['error']}")
        else:
            print(f"📋 执行结果:\n{result.get('stdout', '')}")
    
    def _handle_service(self, cmd: str):
        parts = cmd.split()
        
        if cmd == "service pending":
            pending = self.billing.list_pending()
            print(f"\n📋 待审核申请 ({len(pending)} 个):")
            for p in pending:
                print(f"  {p['application_id']} - {p['contact_name']} ({p['company']}) - {p['purpose']}")
        
        elif cmd.startswith("service view "):
            app_id = parts[2]
            detail = None
            for a in self.shenshi.memory["service_applications"]:
                if a["application_id"] == app_id:
                    detail = a
                    break
            
            if not detail:
                print("❌ 申请不存在")
            else:
                print(f"\n📄 申请详情 {app_id}:")
                for k, v in detail.items():
                    if k not in ["proof_files", "business_license", "id_photo"]:
                        print(f"  {k}: {v}")
        
        elif cmd.startswith("service approve "):
            app_id = parts[2]
            notes = input("审核备注: ").strip()
            result = self.billing.review_application(app_id, True, notes)
            print(result.get("message"))
        
        elif cmd.startswith("service reject "):
            app_id = parts[2]
            notes = input("拒绝原因: ").strip()
            result = self.billing.review_application(app_id, False, notes)
            print(result.get("message"))
        
        else:
            print("未知 service 命令，可用: service pending / service view <id> / service approve <id> / service reject <id>")
    
