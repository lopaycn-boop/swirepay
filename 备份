            "fee_amount": 0,
            "fee_paid": False,
            "api_key": "",
            "api_secret": "",
            "notes": ""
        }
        self.shenshi.memory["service_applications"].append(application)
        self.shenshi.memory["pending_approval"].append(application["application_id"])
        self.shenshi._save()
        return {
            "success": True,
            "application_id": application["application_id"],
            "message": "申请已提交，等待人工审核"
        }
    
    def _calculate_fee(self, app: Dict) -> float:
        volume_map = {
            "small": 100,
            "medium": 500,
            "large": 2000,
            "enterprise": 5000
        }
        return volume_map.get(app.get("expected_volume", "small"), 100)
    
    def review_application(self, application_id: str, approve: bool, notes: str = "") -> Dict:
        app = None
        for a in self.shenshi.memory["service_applications"]:
            if a["application_id"] == application_id:
                app = a
                break
        if not app:
            return {"error": "申请不存在"}
        if approve:
            fee = self._calculate_fee(app)
            app["status"] = "fee_pending"
            app["fee_amount"] = fee
            app["review_notes"] = notes
            app["reviewed_at"] = datetime.now().isoformat()
            if application_id in self.shenshi.memory["pending_approval"]:
                self.shenshi.memory["pending_approval"].remove(application_id)
            self.shenshi._save()
            return {
                "success": True,
                "status": "fee_pending",
                "fee_amount": fee,
                "message": f"已通过，需要支付 {fee} USD 服务费"
            }
        else:
            app["status"] = "rejected"
            app["review_notes"] = notes
            app["reviewed_at"] = datetime.now().isoformat()
            if application_id in self.shenshi.memory["pending_approval"]:
                self.shenshi.memory["pending_approval"].remove(application_id)
            self.shenshi._save()
            return {
                "success": True,
                "status": "rejected",
                "message": "已拒绝申请"
            }
    
    def pay_service_fee(self, application_id: str) -> Dict:
        app = None
        for a in self.shenshi.memory["service_applications"]:
            if a["application_id"] == application_id:
                app = a
                break
        if not app:
            return {"error": "申请不存在"}
        if app["status"] != "fee_pending":
            return {"error": "当前状态不可支付"}
        fee = app["fee_amount"]
        service_order = Order(
            order_id=f"SVC{int(time.time())}{random.randint(1000,9999)}",
            amount=fee,
            currency="USD",
            channel="internal",
            buyer_name=app.get("contact_name", ""),
            buyer_id=app.get("user_id", ""),
            items=[{"name": f"小土豆服务费 - {application_id}", "price": fee, "quantity": 1}],
            status="pending",
            created_at=datetime.now().isoformat()
        )
        payment_result = self.ecommerce.process_payment(service_order)
        if payment_result.get("success"):
            app["status"] = "approved"
            app["fee_paid"] = True
            app["paid_at"] = datetime.now().isoformat()
            app["payment_id"] = payment_result.get("payment_id")
            api_key = hashlib.sha256(f"{app['application_id']}{time.time()}".encode()).hexdigest()[:32]
            api_secret = base64.b64encode(hashlib.sha512(f"{app['application_id']}{random.random()}".encode()).digest()).decode()[:48]
            app["api_key"] = api_key
            app["api_secret"] = api_secret
            self.shenshi.memory["service_users"][app["user_id"]] = {
                "application_id": application_id,
                "api_key": api_key,
                "api_secret": api_secret,
                "created_at": datetime.now().isoformat(),
                "expires_at": (datetime.now() + timedelta(days=365)).isoformat(),
                "plan": app.get("expected_volume", "small")
            }
            self.shenshi._save()
            return {
                "success": True,
                "api_key": api_key,
                "api_secret": api_secret,
                "message": "支付成功，密钥已生成"
            }
        else:
            return {"error": f"支付失败: {payment_result.get('error')}"}
    
    def validate_api_key(self, api_key: str, api_secret: str) -> Dict:
        for user_id, user_info in self.shenshi.memory["service_users"].items():
            if user_info["api_key"] == api_key and user_info["api_secret"] == api_secret:
                if datetime.now() < datetime.fromisoformat(user_info["expires_at"]):
                    return {
                        "valid": True,
                        "user_id": user_id,
                        "plan": user_info["plan"]
                    }
                else:
                    return {"valid": False, "reason": "密钥已过期"}
        return {"valid": False, "reason": "无效密钥"}
    
    def list_pending(self) -> List[Dict]:
        pending = []
        for app_id in self.shenshi.memory["pending_approval"]:
            for app in self.shenshi.memory["service_applications"]:
                if app["application_id"] == app_id:
                    pending.append({
                        "application_id": app["application_id"],
                        "user_id": app["user_id"],
                        "contact_name": app["contact_name"],
                        "company": app.get("company_name", "个人"),
                        "purpose": app["purpose"],
                        "submitted_at": app["submitted_at"]
                    })
        return pending
    
    def list_active_users(self) -> List[Dict]:
        users = []
        for user_id, info in self.shenshi.memory["service_users"].items():
            users.append({
                "user_id": user_id,
                "api_key": info["api_key"][:8] + "...",
                "plan": info["plan"],
                "created_at": info["created_at"],
                "expires_at": info["expires_at"]
            })
        return users


