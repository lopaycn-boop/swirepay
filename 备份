# ==================== 神石记忆系统 ====================

class ShenshiMemory:
    def __init__(self):
        self.file = CONFIG["shenshi_file"]
        self.data_dir = CONFIG["data_dir"]
        os.makedirs(self.data_dir, exist_ok=True)
        self.memory = self._load()
        self._ensure_structure()
    
    def _load(self) -> Dict:
        if os.path.exists(self.file):
            try:
                with open(self.file, 'r', encoding='utf-8') as f:
                    return json.load(f)
            except Exception:
                return {}
        return {}
    
    def _save(self):
        with open(self.file, 'w', encoding='utf-8') as f:
            json.dump(self.memory, f, indent=2, ensure_ascii=False)
    
    def _ensure_structure(self):
        if "orders" not in self.memory:
            self.memory["orders"] = []
        if "scraped_data" not in self.memory:
            self.memory["scraped_data"] = []
        if "deployments" not in self.memory:
            self.memory["deployments"] = []
        if "social_accounts" not in self.memory:
            self.memory["social_accounts"] = []
        if "chats" not in self.memory:
            self.memory["chats"] = []
        if "facts" not in self.memory:
            self.memory["facts"] = {"爸爸的名字": "自由的风"}
        if "stats" not in self.memory:
            self.memory["stats"] = {
                "total_orders": 0,
                "total_scrapes": 0,
                "total_deploys": 0,
                "total_chats": 0,
                "first_seen": datetime.now().isoformat()
            }
        self._save()
    
    def add_order(self, order: Order):
        self.memory["orders"].append(asdict(order))
        self.memory["stats"]["total_orders"] += 1
        self._save()
    
    def add_scraped_data(self, data: ScrapedData):
        self.memory["scraped_data"].append(asdict(data))
        self.memory["stats"]["total_scrapes"] += 1
        self._save()
    
    def add_deployment(self, target: str, config: Dict, result: Dict):
        self.memory["deployments"].append({
            "time": datetime.now().isoformat(),
            "target": target,
            "config": config,
            "result": result
        })
        self.memory["stats"]["total_deploys"] += 1
        self._save()
    
    def add_social_account(self, platform: str, account_info: Dict):
        self.memory["social_accounts"].append({
            "time": datetime.now().isoformat(),
            "platform": platform,
            "account": account_info
        })
        self._save()
    
    def add_chat(self, user_msg: str, bot_reply: str):
        self.memory["chats"].append({
            "time": datetime.now().isoformat(),
            "user": user_msg,
            "bot": bot_reply
        })
        self.memory["stats"]["total_chats"] += 1
        if len(self.memory["chats"]) > 100:
            self.memory["chats"] = self.memory["chats"][-100:]
        self._save()
    
    def add_fact(self, key: str, value: str):
        self.memory["facts"][key] = value
        self._save()
    
    def get_fact(self, key: str) -> str:
        return self.memory["facts"].get(key, "自由的风")
    
    def save_file(self, filename: str, content: str) -> str:
        filepath = os.path.join(self.data_dir, filename)
        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(content)
        return filepath


# ==================== 电商交易模块 ====================

class EcommerceModule:
    def __init__(self, shenshi: ShenshiMemory):
        self.shenshi = shenshi
        self.api_base = CONFIG["pay9_api_url"]
        self.api_key = CONFIG["pay9_api_key"]
        self.api_secret = CONFIG["pay9_api_secret"]
    
    def _sign_request(self, method: str, path: str, body: str = "", timestamp: int = None) -> str:
        timestamp = timestamp or int(time.time() * 1000)
        message = f"{method}\n{path}\n{timestamp}\n{body}"
        return hashlib.sha256(f"{message}{self.api_secret}".encode()).hexdigest()
    
    def _api_call(self, method: str, endpoint: str, data: Dict = None) -> Dict:
        if not self.api_key or not self.api_secret:
            return {"success": False, "error": "API密钥未配置"}
        
        url = f"{self.api_base}{endpoint}"
        timestamp = int(time.time() * 1000)
        body = json.dumps(data) if data else ""
        
        headers = {
            "X-API-Key": self.api_key,
            "X-Timestamp": str(timestamp),
            "X-Signature": self._sign_request(method, endpoint, body, timestamp),
            "Content-Type": "application/json"
        }
        
        try:
            if method.upper() == "GET":
                resp = requests.get(url, params=data, headers=headers, timeout=30)
            else:
                resp = requests.post(url, json=data, headers=headers, timeout=30)
            resp.raise_for_status()
            return resp.json()
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def create_order(self, buyer_name: str, buyer_id: str, items: List[Dict], channel: str) -> Order:
        total = sum(item.get("price", 0) * item.get("quantity", 1) for item in items)
        currency = items[0].get("currency", "USD") if items else "USD"
        
        order = Order(
            order_id=f"ORD{int(time.time())}{random.randint(1000,9999)}",
            amount=total,
            currency=currency,
            channel=channel,
            buyer_name=buyer_name,
            buyer_id=buyer_id,
            items=items,
            status="pending",
            created_at=datetime.now().isoformat(),
            risk_score=0.1 if total < CONFIG["large_amount_threshold"] else 0.5
        )
        
        self.shenshi.add_order(order)
        return order
    
    def process_payment(self, order: Order) -> Dict:
        result = self._api_call("POST", "/payment/create", {
            "order_id": order.order_id,
            "amount": order.amount,
            "currency": order.currency,
            "channel": order.channel,
            "buyer_id": order.buyer_id
        })
        
        if result.get("success", False):
            order.status = "paid"
            order.paid_at = datetime.now().isoformat()
        
        return result
    
    def check_balance(self) -> Dict:
        return self._api_call("GET", "/balance")


# ==================== 网络爬虫模块 ====================

class ScraperModule:
    def __init__(self, shenshi: ShenshiMemory):
        self.shenshi = shenshi
        self.config = CONFIG["scraper"]
        self.session = requests.Session()
        self.last_request = 0
    
    def _rate_limit(self):
        elapsed = time.time() - self.last_request
        delay = random.uniform(self.config["min_delay"], self.config["max_delay"])
        if elapsed < delay:
            time.sleep(delay - elapsed)
        self.last_request = time.time()
    
    def _get_headers(self) -> Dict:
        return {
            "User-Agent": random.choice(self.config["user_agents"]),
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
            "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8"
        }
    
    def get(self, url: str, params: Dict = None) -> Optional[requests.Response]:
        self._rate_limit()
        
        for attempt in range(self.config["max_retries"]):
            try:
                resp = self.session.get(
                    url,
                    params=params,
                    headers=self._get_headers(),
                    timeout=30
                )
                resp.raise_for_status()
                return resp
            except Exception:
                if attempt == self.config["max_retries"] - 1:
                    return None
                time.sleep(2 ** attempt)
        return None
    
    def scrape_static(self, url: str, rules: Dict[str, str]) -> Dict:
        resp = self.get(url)
        if not resp:
            return {"error": "请求失败"}
        
        from bs4 import BeautifulSoup
        soup = BeautifulSoup(resp.text, 'html.parser')
        
        result = {}
        for field, selector in rules.items():
            elem = soup.select_one(selector)
            result[field] = elem.get_text(strip=True) if elem else None
        
        self.shenshi.add_scraped_data(ScrapedData(
            url=url,
            title=result.get("title", ""),
            content=resp.text[:500],
            data=result,
            created_at=datetime.now().isoformat()
        ))
        
        return result
    
    def download_file(self, url: str, filename: str = None) -> Optional[str]:
        resp = self.get(url)
        if not resp:
            return None
        
        if not filename:
            filename = url.split('/')[-1].split('?')[0]
            if not filename:
                filename = hashlib.md5(url.encode()).hexdigest()
        
        filepath = self.shenshi.save_file(filename, resp.text)
        return filepath


