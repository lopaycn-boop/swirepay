class RemoteModule:
    def __init__(self, shenshi: ShenshiMemory):
        self.shenshi = shenshi
        self.tg_token = CONFIG["tg_bot_token"]
        self.tg_chat = CONFIG["tg_chat_id"]
    
    def send_telegram(self, message: str) -> bool:
        if not self.tg_token or not self.tg_chat:
            return False
        
        url = f"https://api.telegram.org/bot{self.tg_token}/sendMessage"
        data = {"chat_id": self.tg_chat, "text": message}
        
        try:
            requests.post(url, json=data, timeout=5)
            return True
        except Exception:
            return False
    
    def execute_command(self, command: str) -> Dict:
        allowed = ["ls", "pwd", "date", "echo", "cat"]
        cmd_parts = command.split()
        
        if not cmd_parts:
            return {"error": "命令不能为空"}
        
        if cmd_parts[0] not in allowed:
            return {"error": "命令不在白名单内"}
        
        try:
            result = subprocess.run(
                command.split(),
                capture_output=True,
                text=True,
                timeout=10
            )
            return {
                "stdout": result.stdout,
                "stderr": result.stderr,
                "returncode": result.returncode
            }
        except Exception as e:
            return {"error": str(e)}


